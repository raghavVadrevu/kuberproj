# Database (local Docker defaults; override in production)
# DB_HOST=127.0.0.1
# DB_PORT=5433
# DB_USER=huddle
# DB_PASSWORD=huddle_dev
# DB_NAME=huddle

# Cognito
# COGNITO_ISSUER=https://cognito-idp.REGION.amazonaws.com/REGION_poolId
# COGNITO_APP_CLIENT_ID=your_app_client_id

# Object storage — MinIO locally (docker-compose sets these on the api service)
# S3_ENDPOINT=http://minio:9000
# S3_PUBLIC_ENDPOINT=http://localhost:9000
# When running the API on the host (not in Docker), use the same value for both endpoints.
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=huddle-uploads
# S3_PUBLIC_BASE_URL=http://localhost:9000/huddle-uploads
# S3_USE_PATH_STYLE=true
# S3_REGION=us-east-1

# Production AWS S3 (leave S3_ENDPOINT unset; use IAM task role or keys)
# S3_BUCKET=your-prod-bucket
# S3_PUBLIC_BASE_URL=https://your-prod-bucket.s3.ap-south-1.amazonaws.com
# S3_REGION=ap-south-1
# AVATAR_MAX_BYTES=2097152
# Bucket CORS must allow PUT from your frontend origin, e.g. https://app.example.com
# IAM/task role needs s3:PutObject on arn:aws:s3:::your-prod-bucket/avatars/*

# Local LLM (Docker Ollama — docker-compose sets these on the api service)
# LLM_LOCAL_MODEL=ollama/llama3.2:1b
# LLM_MAX_TOKENS=384
# OLLAMA_API_BASE=http://ollama:11434

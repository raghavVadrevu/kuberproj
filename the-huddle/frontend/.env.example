# Amazon Cognito (browser signup). Restart dev server after changes.
VITE_COGNITO_ISSUER=https://cognito-idp.REGION.amazonaws.com/REGION_poolId
VITE_COGNITO_CLIENT_ID=your_app_client_id

# Same as app client id if you prefer this name:
# VITE_COGNITO_AUDIENCE=

# Optional if issuer URL is not used:
# VITE_COGNITO_USER_POOL_ID=

# Backend (Vite dev proxies /api → http://127.0.0.1:8000). Override for a remote API.
# VITE_API_BASE=/api
